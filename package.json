{
  "name": "aetherdtl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "C++ DTL intent network simulator with TypeScript integration tests.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/build.mjs && node --test \"tests/node/*.test.ts\"",
    "ci": "node scripts/build.mjs --warnings && node --test \"tests/node/*.test.ts\"",
    "loc": "node scripts/check-loc.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
